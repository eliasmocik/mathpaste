#!/usr/bin/env bash
# mathpaste — CLI wrapper. Runs the converter using the project's own venv,
# so it works no matter which directory you call it from (and from Hammerspoon).
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$HERE/.venv/bin/python" "$HERE/mathpaste.py" "$@"
